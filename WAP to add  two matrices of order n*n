#include<stdio.h>

int main() {

    int n;

    printf("Enter order of matrix: ");
    scanf("%d", &n);

    int a[n][n], b[n][n], sum[n][n];

    // Input first matrix
    printf("Enter elements of first matrix:\n");

    for(int i = 0; i < n; i++) {

        for(int j = 0; j < n; j++) {

            scanf("%d", &a[i][j]);
        }
    }

    // Input second matrix
    printf("Enter elements of second matrix:\n");

    for(int i = 0; i < n; i++) {

        for(int j = 0; j < n; j++) {

            scanf("%d", &b[i][j]);
        }
    }

    // Addition
    for(int i = 0; i < n; i++) {

        for(int j = 0; j < n; j++) {

            sum[i][j] = a[i][j] + b[i][j];
        }
    }

    // Display result
    printf("Sum Matrix:\n");

    for(int i = 0; i < n; i++) {

        for(int j = 0; j < n; j++) {

            printf("%d ", sum[i][j]);
        }

        printf("\n");
    }

    return 0;
}
