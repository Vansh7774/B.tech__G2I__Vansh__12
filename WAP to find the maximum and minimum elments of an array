#include<stdio.h>

int main() {

    int n;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    // Input array elements
    for(int i = 0; i < n; i++) {

        printf("Enter element %d: ", i + 1);
        scanf("%d", &arr[i]);
    }

    // Assume first element is max and min
    int max = arr[0];
    int min = arr[0];

    // Find max and min
    for(int i = 1; i < n; i++) {

        if(arr[i] > max) {

            max = arr[i];
        }

        if(arr[i] < min) {

            min = arr[i];
        }
    }

    printf("Maximum element = %d\n", max);
    printf("Minimum element = %d", min);

    return 0;
}
