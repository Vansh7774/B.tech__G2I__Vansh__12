#include<stdio.h>

int main() {

    int n, key, found = 0;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    // Input array elements
    for(int i = 0; i < n; i++) {

        printf("Enter element %d: ", i + 1);
        scanf("%d", &arr[i]);
    }

    // Element to search
    printf("Enter element to search: ");
    scanf("%d", &key);

    // Linear Search
    for(int i = 0; i < n; i++) {

        if(arr[i] == key) {

            printf("Element found at position %d", i + 1);

            found = 1;

            break;
        }
    }

    if(found == 0) {

        printf("Element not found");
    }

    return 0;
}
