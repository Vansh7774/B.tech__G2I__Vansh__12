#include<stdio.h>

int main() {

    int n, key, low, high, mid, found = 0;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    // Input sorted array
    printf("Enter elements in sorted order:\n");

    for(int i = 0; i < n; i++) {

        scanf("%d", &arr[i]);
    }

    // Element to search
    printf("Enter element to search: ");
    scanf("%d", &key);

    low = 0;
    high = n - 1;

    // Binary Search
    while(low <= high) {

        mid = (low + high) / 2;

        if(arr[mid] == key) {

            printf("Element found at position %d", mid + 1);

            found = 1;

            break;
        }
        else if(arr[mid] < key) {

            low = mid + 1;
        }
        else {

            high = mid - 1;
        }
    }

    if(found == 0) {

        printf("Element not found");
    }

    return 0;
}
