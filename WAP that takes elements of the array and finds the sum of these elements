#include<stdio.h>

int main() {

    int n, sum = 0;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    // Input array elements
    for(int i = 0; i < n; i++) {

        printf("Enter element %d: ", i + 1);
        scanf("%d", &arr[i]);
    }

    // Calculate sum
    for(int i = 0; i < n; i++) {

        sum = sum + arr[i];
    }

    printf("Sum of array elements = %d", sum);

    return 0;
}
