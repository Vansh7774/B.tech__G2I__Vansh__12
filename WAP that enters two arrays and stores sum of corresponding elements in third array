#include<stdio.h>

int main() {

    int n;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr1[n], arr2[n], arr3[n];

    // Input first array
    printf("Enter elements of first array:\n");

    for(int i = 0; i < n; i++) {

        scanf("%d", &arr1[i]);
    }

    // Input second array
    printf("Enter elements of second array:\n");

    for(int i = 0; i < n; i++) {

        scanf("%d", &arr2[i]);
    }

    // Sum of corresponding elements
    for(int i = 0; i < n; i++) {

        arr3[i] = arr1[i] + arr2[i];
    }

    // Display third array
    printf("Sum array is:\n");

    for(int i = 0; i < n; i++) {

        printf("%d ", arr3[i]);
    }

    return 0;
}
