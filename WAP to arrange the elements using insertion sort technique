#include<stdio.h>

int main() {

    int n, temp, j;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    // Input array elements
    for(int i = 0; i < n; i++) {

        printf("Enter element %d: ", i + 1);
        scanf("%d", &arr[i]);
    }

    // Insertion Sort
    for(int i = 1; i < n; i++) {

        temp = arr[i];
        j = i - 1;

        while(j >= 0 && arr[j] > temp) {

            arr[j + 1] = arr[j];
            j--;
        }

        arr[j + 1] = temp;
    }

    // Display sorted array
    printf("Sorted array:\n");

    for(int i = 0; i < n; i++) {

        printf("%d ", arr[i]);
    }

    return 0;
}
